# Optional: full API base URL when not using Vite dev proxy
# VITE_API_URL=http://localhost:3001

# Dev server bind (see vite.config.ts). Astrill / VPN: use loopback only.
# - Leave unset or empty: listen on all interfaces → http://YOUR_LAN_IP:5173 (e.g. 172.16.1.188) when VPN is off
# - DEV_HOST=127.0.0.1: same as `npm run dev:vpn` → open http://127.0.0.1:5173 (works with Astrill on)
# DEV_HOST=127.0.0.1
